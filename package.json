{
  "name": "uwork",
  "version": "1.0.2",
  "description": "Brazilian public company dataset API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=tests/unit --runInBand --forceExit",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "csv-writer": "^1.6.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "i18next": "^25.8.17",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.9.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "moduleNameMapper": {
      "^@config/(.*)$": "<rootDir>/src/config/$1",
      "^@core/(.*)$": "<rootDir>/src/core/$1",
      "^@modules/(.*)$": "<rootDir>/src/modules/$1",
      "^@types/(.*)$": "<rootDir>/src/@types/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/server.ts",
      "!src/@types/**"
    ],
    "coverageDirectory": "coverage"
  }
}
