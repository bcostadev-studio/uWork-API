# Server
NODE_ENV=development
PORT=3000

# Hostname used for Swagger server URLs and HTTPS virtual host matching
# dev  → uwork.api.dev  (registered in /etc/hosts → 127.0.0.1)
# prod → uwork.api.prod (registered in /etc/hosts → 127.0.0.1)
API_HOST=uwork.api.dev

# Upstream data providers (Brazilian public APIs)
BRASIL_API_BASE_URL=https://brasilapi.com.br/api
RECEITAWS_BASE_URL=https://receitaws.com.br/v1

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# CORS — use * for all origins or a comma-separated list of allowed origins
CORS_ORIGIN=*
