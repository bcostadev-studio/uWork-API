# Server
NODE_ENV=development
PORT=3000

# Upstream data providers (Brazilian public APIs)
BRASIL_API_BASE_URL=https://brasilapi.com.br/api
RECEITAWS_BASE_URL=https://receitaws.com.br/v1

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# CORS — use * for all origins or a comma-separated list of allowed origins
CORS_ORIGIN=*
